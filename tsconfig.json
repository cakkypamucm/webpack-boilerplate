{
    "extends": "@tsconfig/recommended/tsconfig.json",
    "compilerOptions": {
        "moduleResolution": "bundler",
        "module": "es2022",
        "target": "es2022",
        "allowJs": true,
        "sourceMap": true,
        "resolveJsonModule": true,
        "paths": {
            "src/*": ["./src/*"]
        }
    },
    "include": ["src/**/*.ts", "src/**/*.vue"]
}
