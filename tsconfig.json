{
    "extends": "@tsconfig/recommended/tsconfig.json",
    "compilerOptions": {
        "moduleResolution": "bundler",
        "module": "es2022",
        "target": "es2022",
        "noEmit": true,
        "incremental": true,
        "tsBuildInfoFile": ".tsbuildcache",
        "allowJs": true,
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": ["src/**/*.ts", "src/**/*.vue"]
}
